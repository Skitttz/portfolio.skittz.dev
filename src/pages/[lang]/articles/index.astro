---
import LangToggle from "@/components/astro/LangToggle.astro";
import NotFoundArticle from "@/components/astro/NotFoundArticle.astro";
import { formatDate } from "@/utils/format-date";
import { getHrefLang } from "@/utils/get-href-lang.ts";
import Footer from "@components/astro/Footer.astro";
import ThemeToggle from "@components/astro/ThemeToggle.astro";
import Layout from "@layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const lang = Astro.params.lang ?? "pt-br";

const immersiveCopy = {
  en: {
    homeLabel: "Back home",
    emptyHint: "No entries yet. New write-ups coming soon.",
  },
  "pt-br": {
    homeLabel: "Voltar para home",
    emptyHint: "Ainda sem entradas. Novos textos em breve.",
  },
};

const posts = (await getCollection("articles")).filter(
  (post) => post.data.lang === lang,
);

const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const ui =
  immersiveCopy[lang as keyof typeof immersiveCopy] || immersiveCopy.en;
---

<Layout lang={lang} title="Blog">
  <div class="fixed top-6 right-6 z-[9999]">
    <ThemeToggle />
  </div>

  <div class="fixed top-6 right-20 z-[9999]">
    <LangToggle lang={lang} />
  </div>

  <div class="flex flex-col min-h-[100dvh] relative">
    <div
      class="absolute inset-0 bg-gradient-to-br from-gray-50 via-gray-100 to-gray-200 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900"
    >
      <div
        class="absolute inset-0 opacity-[0.02] dark:opacity-[0.05]"
        style="background-image: radial-gradient(circle at 1px 1px, rgba(0,0,0,0.15) 1px, transparent 0); background-size: 20px 20px;"
      >
      </div>
    </div>
    <div class="relative z-50 pt-8 px-6">
      <div class="max-w-4xl mx-auto text-left">
        <a
          href={getHrefLang(lang)}
          aria-label={ui.homeLabel}
          class="inline-flex items-center p-3 bg-gray-200/50 dark:bg-gray-700/50 backdrop-blur-sm rounded-xl hover:bg-gray-200/70 dark:hover:bg-gray-700/70 transition-all duration-200 text-gray-700 dark:text-gray-300 hover:scale-105 border border-gray-300/50 dark:border-gray-600/50"
        >
          <Icon name="mdi:home" />
        </a>
      </div>
    </div>

    <main class="relative z-50 flex-grow px-6 py-12 animate-blurIn">
      <div class="max-w-4xl mx-auto space-y-6">
        {
          sortedPosts.map((post, index) => (
            <article
              class="group animate-fadeInUp"
              style={`animation-delay: ${220 + index * 90}ms`}
            >
              <a
                href={`/${post.data.lang}/articles/${post.id}`}
                class="article-node flex items-start gap-4 bg-white/50 dark:bg-gray-800/50 backdrop-blur-sm rounded-2xl p-6 hover:bg-white/70 dark:hover:bg-gray-800/70 transition-all duration-300 hover:scale-[1.01] hover:shadow-lg border border-gray-200/50 dark:border-gray-700/50"
              >
                <img
                  class="w-14 h-14 rounded-xl object-cover shrink-0 ring-1 ring-slate-300/60 dark:ring-slate-600/70"
                  src="https://github.com/skitttz.png"
                  alt="Avatar"
                />

                <div class="flex-1 space-y-2">
                  <time
                    datetime={post.data.date.toISOString()}
                    class="text-xs text-gray-500 dark:text-gray-400 font-medium"
                  >
                    {formatDate(new Date(post.data.date), lang)}
                  </time>
                  <h2 class="text-lg md:text-xl font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-200">
                    {post.data.title}
                  </h2>
                  {post.data.description && (
                    <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
                      {post.data.description}
                    </p>
                  )}
                </div>

                <div class="node-chevron" aria-hidden="true">
                  <Icon name="mdi:arrow-right" />
                </div>
              </a>
            </article>
          ))
        }

        {
          sortedPosts.length === 0 && (
            <div
              class="space-y-3 animate-fadeInUp"
              style="animation-delay: 260ms"
            >
              <p class="text-sm text-slate-600 dark:text-slate-300">
                {ui.emptyHint}
              </p>
              <NotFoundArticle lang={lang} />
            </div>
          )
        }
      </div>
    </main>
    <Footer lang={lang} />
  </div>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes blurIn {
    from {
      opacity: 0;
      filter: blur(10px);
    }
    to {
      opacity: 1;
      filter: blur(0);
    }
  }

  .animate-fadeInUp {
    animation: fadeInUp 0.8s ease-out both;
  }

  .animate-blurIn {
    animation: blurIn 1s ease-out;
  }

  .system-head {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .system-lights {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
  }

  .system-light {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
  }

  .is-red {
    background: #fb7185;
  }

  .is-amber {
    background: #fbbf24;
  }

  .is-green {
    background: #34d399;
  }

  .system-title {
    margin: 0;
    font-size: 0.88rem;
    font-weight: 600;
    color: rgb(15, 23, 42);
  }

  .dark .system-title {
    color: rgb(241, 245, 249);
  }

  .system-subtitle {
    margin: 0.2rem 0 0;
    font-size: 0.78rem;
    color: rgb(71, 85, 105);
  }

  .dark .system-subtitle {
    color: rgb(148, 163, 184);
  }

  .node-chevron {
    margin-left: auto;
    display: flex;
    align-items: center;
    color: rgb(100, 116, 139);
    transform: translateX(-2px);
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }

  .group:hover .node-chevron {
    color: rgb(37, 99, 235);
    transform: translateX(2px);
  }

  .dark .node-chevron {
    color: rgb(148, 163, 184);
  }

  .dark .group:hover .node-chevron {
    color: rgb(96, 165, 250);
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fadeInUp,
    .animate-blurIn {
      animation: none !important;
    }
  }
</style>
