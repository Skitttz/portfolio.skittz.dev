---
import Hero from "@components/astro/Hero.astro";
import Footer from "@components/astro/Footer.astro";
import TerminalSections from "@components/astro/TerminalSections.astro";
import Layout from "@layouts/Layout.astro";
import en from "@locales/en.json";
import pt from "@locales/pt-br.json";

const lang = Astro.params.lang ?? "pt-br";
const locales: Record<string, typeof pt> = { en, pt };
const translations = locales[lang as keyof typeof locales] || pt;
---

<Layout lang={lang} title="Portfolio {Carlos Vinicius}" class:list={"h-dvh"}>
  <Hero
    lang={lang}
    button={{
      textPrimary: translations.button.textPrimary,
      textSecondary: translations.button.textSecondary,
    }}
    textIntro={translations.textIntro}
    answer={translations.answer}
    name={translations.name}
    selfProfissionalText={translations.selfProfissionalText}
    tagline={translations.tagline}
    nickname={translations.nickname}
    fileName={translations.fileName}
    linkedInText={translations.linkedInText}
    about={{
      title: translations.about.title,
      description: translations.about.description,
      location: translations.about.location,
      role: translations.about.role,
    }}
  />

  <TerminalSections lang={lang} />

  <Footer lang={lang} />
</Layout>
